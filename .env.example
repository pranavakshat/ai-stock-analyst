# ── Copy this file to .env and fill in every value ───────────────────────────
# NEVER commit .env to git.

# General
APP_SECRET_KEY=replace-with-a-random-secret
DEBUG=false
PORT=5000

# Database (relative path — created automatically on first run)
DATABASE_PATH=data/predictions.db

# ── AI Model Keys ─────────────────────────────────────────────────────────────
# Claude: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ChatGPT: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Gemini: https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=AIza...

# Grok: https://console.x.ai
XAI_API_KEY=xai-...

# Copilot (Azure OpenAI): https://portal.azure.com > Azure OpenAI
AZURE_OPENAI_KEY=your-azure-key
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com/
AZURE_OPENAI_DEPLOY=gpt-4o  # name of your deployment in Azure

# ── Email ─────────────────────────────────────────────────────────────────────
# Use a Gmail App Password (not your normal login password).
# Enable 2FA then create one at: https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your.sender@gmail.com
GMAIL_APP_PASS=xxxx xxxx xxxx xxxx
EMAIL_RECIPIENT=pranav.akshat.2@gmail.com

# ── Scheduler ─────────────────────────────────────────────────────────────────
MORNING_HOUR=5
MORNING_MINUTE=0
EVENING_HOUR=18
EVENING_MINUTE=0
TIMEZONE=America/New_York

# ── Portfolio ─────────────────────────────────────────────────────────────────
STARTING_PORTFOLIO_VALUE=10000
